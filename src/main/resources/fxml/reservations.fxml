<?xml version="1.0" encoding="UTF-8"?>

<?import io.github.palexdev.materialfx.controls.MFXButton?>
<?import io.github.palexdev.materialfx.controls.MFXDatePicker?>
<?import io.github.palexdev.materialfx.controls.MFXTableView?>
<?import io.github.palexdev.materialfx.controls.MFXTextField?>
<?import io.github.palexdev.materialfx.controls.MFXToggleButton?>
<?import javafx.scene.layout.AnchorPane?>

<AnchorPane fx:id="reservationsRoot" maxHeight="-Infinity" maxWidth="-Infinity" minHeight="-Infinity"
            minWidth="-Infinity" prefHeight="770.0" prefWidth="990.0"
            stylesheets="@/css/reservations.css" xmlns="http://javafx.com/javafx/25"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.reservio.reservation_system.reservationsystemdesktop.controller.ReservationsController">
    <children>
        <MFXTableView fx:id="reservationsTable" layoutX="477.0" layoutY="347.0"
                      styleClass="main-table" AnchorPane.bottomAnchor="80.0" AnchorPane.leftAnchor="15.0"
                      AnchorPane.rightAnchor="15.0" AnchorPane.topAnchor="80.0"/>
        <MFXDatePicker fx:id="dateFrom" layoutX="542.0" layoutY="22.0"
                       promptText="Od" styleClass="main-datepicker"/>
        <MFXDatePicker fx:id="dateTo" layoutX="775.0" layoutY="22.0"
                       promptText="Do" styleClass="main-datepicker"/>
        <MFXTextField fx:id="txtSearchClient" layoutX="15.0" layoutY="16.0"
                      prefHeight="0.0" prefWidth="224.0" promptText="Wszukaj klienta"
                      styleClass="main-textfield"/>
        <MFXButton fx:id="btnCreateReservation" layoutX="15.0" layoutY="710.0"
                   prefHeight="38.0" prefWidth="182.0"
                   styleClass="primary-btn" text="Utwórz rezerwacje"/>
        <MFXToggleButton fx:id="btnShowCompleted" layoutX="719.0" layoutY="709.0"
                         styleClass="secondary-toggle" text="Pokaż zakończone rezerwacje"/>
    </children>
</AnchorPane>
